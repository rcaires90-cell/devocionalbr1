/* ═══ STORAGE (localStorage) ═══ */
function load(key, fallback) {
  try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : fallback; }
  catch { return fallback; }
}
function save(key, val) {
  try { localStorage.setItem(key, JSON.stringify(val)); } catch(e) { console.warn("save", e); }
}

/* ═══ API — calls our serverless proxy ═══ */
async function api(sys, msgs, tools) {
  const body = { system: sys, messages: msgs };
  if (tools) body.tools = tools;
  const r = await fetch("/api/claude", {
    method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body)
  });
  if (!r.ok) { const err = await r.json().catch(() => ({})); throw new Error(err.error || `Erro ${r.status}`); }
  return await r.json();
}

function extractText(data) {
  return (data?.content || []).filter(b => b.type === "text").map(b => b.text).join("\n") || "";
}

async function generateContent(type, dayNum, usedTitles) {
  const usedStr = usedTitles.length > 0 ? `\nJÁ USADOS (NÃO REPITA): ${usedTitles.join("; ")}` : "";
  const hints = {
    "Versículo Dark": "Versículos sombrios e poderosos que causam arrepios. Visual escuro cinematográfico.",
    "Reflexão Profunda": "Perguntas existenciais pesadas. Tom filosófico e bíblico profundo.",
    "Curiosidade Bíblica": "Fatos BIZARROS ou DESCONHECIDOS da Bíblia. Clickbait bíblico irresistível.",
    "Motivacional": "Como se Deus falasse diretamente com a pessoa. Tom urgente e pessoal.",
    "Mistério Bíblico": "Eventos sobrenaturais inexplicáveis da Bíblia. Atmosfera de mistério.",
    "Profecia": "Profecias bíblicas que parecem se cumprir AGORA. Senso de urgência.",
    "Série Noturna": "Conteúdo para antes de dormir. Versículos de paz com tom calmo mas profundo."
  };
  const data = await api(
    `Gerador de conteúdo viral TikTok dark devocional @${U}. Responda SOMENTE com JSON válido, sem markdown, sem backticks. Estrutura: {"titulo":"string","gancho":"string","versiculo":"string","narracao":"string (150-200 palavras)","cta":"string","legenda":"string (com emojis)","hashtags":"string (15 hashtags)","estilo_video":"string","thumbnail":"string","musica":"string","dica_viral":"string"}`,
    [{ role: "user", content: `DIA ${dayNum}, Tipo:"${type}". ${hints[type]||""} Versículos POUCO CONHECIDOS. Gancho impossível de ignorar.${usedStr}\nApenas JSON.` }]
  );
  const raw = extractText(data);
  if (!raw) throw new Error("Resposta vazia da IA");
  const cleaned = raw.replace(/```json\s*/gi, "").replace(/```\s*/gi, "").trim();
  try { return JSON.parse(cleaned); } catch {}
  const match = cleaned.match(/\{[\s\S]*\}/);
  if (match) return JSON.parse(match[0]);
  throw new Error("IA não retornou JSON válido");
}

async function searchWeb(prompt) {
  const data = await api(
    `Analista de TikTok devocional dark. PT-BR, **negrito**, emojis. Específico e prático.`,
    [{ role: "user", content: prompt }],
    [{ type: "web_search_20250305", name: "web_search" }]
  );
  return extractText(data) || "Sem dados disponíveis.";
}

async function chatWithAI(msgs) {
  const data = await api(
    `Assistente @${U} (TikTok dark devocional). PT-BR, **negrito**, emojis, prático. Pode pesquisar na web.`,
    msgs,
    [{ type: "web_search_20250305", name: "web_search" }]
  );
  return extractText(data) || "Erro. Tente novamente.";
}

/* ═══ COMPONENTS ═══ */
function Ring({ value, max, color, size = 80, sw = 5, children }) {
  const pct = Math.min(100, max > 0 ? (value / max) * 100 : 0);
  const r = (size - sw * 2) / 2, c = 2 * Math.PI * r, off = c - (pct / 100) * c;
  return (
    <div style={{ position: "relative", width: size, height: size, display: "flex", alignItems: "center", justifyContent: "center" }}>
      <svg width={size} height={size} style={{ position: "absolute", transform: "rotate(-90deg)" }}>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="rgba(255,255,255,0.04)" strokeWidth={sw}/>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth={sw}
          strokeDasharray={c} strokeDashoffset={off} strokeLinecap="round"
          style={{ transition:"stroke-dashoffset 0.8s ease", filter:`drop-shadow(0 0 6px ${color}60)` }}/>
      </svg>
      <div style={{ position:"relative", zIndex:1, textAlign:"center" }}>{children}</div>
    </div>
  );
}

function MD({ text }) {
  if (!text) return null;
  return text.split("\n").map((line, i) => {
    if (line.startsWith("## ")) return <div key={i} style={{ fontSize:"13px", fontWeight:700, color:"#bf5af2", margin:"10px 0 4px", fontFamily:"var(--f1)" }}>{line.slice(3)}</div>;
    if (line.startsWith("# ")) return <div key={i} style={{ fontSize:"15px", fontWeight:700, color:"#ff2d55", margin:"12px 0 5px", fontFamily:"var(--f1)" }}>{line.slice(2)}</div>;
    if (!line.trim()) return <div key={i} style={{ height:"6px" }}/>;
    const parts = []; let rest = line, idx = 0;
    while (rest.includes("**")) {
      const s = rest.indexOf("**"), e = rest.indexOf("**", s+2);
      if (e === -1) break;
      if (s > 0) parts.push(<span key={idx++}>{rest.slice(0, s)}</span>);
      parts.push(<strong key={idx++} style={{ color:"#f0e6d3" }}>{rest.slice(s+2, e)}</strong>);
      rest = rest.slice(e+2);
    }
    if (rest) parts.push(<span key={idx++}>{rest}</span>);
    if (line.match(/^[-•*]\s/)) return <div key={i} style={{ paddingLeft:"16px", margin:"2px 0", position:"relative" }}><span style={{ position:"absolute", left:"4px", color:"#ff2d55" }}>✦</span>{parts.length>1 ? parts : line.replace(/^[-•*]\s/,"")}</div>;
    return <div key={i} style={{ margin:"2px 0", lineHeight:1.6 }}>{parts.length>1 ? parts : line}</div>;
  });
}

function Err({ msg, onRetry }) {
  return <div style={{ background:"rgba(255,45,85,0.06)", borderRadius:"12px", border:"1px solid rgba(255,45,85,0.15)", padding:"14px", textAlign:"center", marginBottom:"10px" }}>
    <div style={{ fontSize:"12px", color:"#ff2d55", marginBottom:"8px" }}>⚠️ {msg}</div>
    {onRetry && <button onClick={onRetry} style={{ padding:"6px 16px", borderRadius:"8px", border:"none", background:"rgba(255,45,85,0.1)", color:"#ff2d55", cursor:"pointer", fontSize:"11px", fontWeight:600 }}>Tentar novamente</button>}
  </div>;
}

