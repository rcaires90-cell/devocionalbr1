          </div>}
          {/* Phase */}
          <div style={{...glass,padding:"18px",marginBottom:"14px",position:"relative",overflow:"hidden"}}><div style={gw(phC)}/><div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}><div><div style={{fontSize:"9px",color:"#4d4538",letterSpacing:"1.5px",fontFamily:"var(--f1)"}}>FASE ATUAL</div><div style={{fontSize:"22px",fontWeight:900,color:phC,fontFamily:"var(--f1)",textShadow:`0 0 25px ${phC}20`}}>{phase}</div></div><Ring value={followers} max={10000} color={phC} size={60} sw={4}><div style={{fontSize:"12px",fontWeight:700,color:phC}}>{Math.min(100,Math.round(followers/100))}%</div></Ring></div><div style={{marginTop:"8px",fontSize:"11px",color:"#6b6358"}}>{followers>=10000?"🎉 Programa disponível!":`Meta: ${(10000-followers).toLocaleString()} seguidores restantes`}</div></div>
          {monErr&&<Err msg={monErr} onRetry={()=>doSync()}/>}
          {report&&<div style={{...glass,padding:"16px",position:"relative",overflow:"hidden"}}><div style={gw("#ff2d5540")}/><div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"10px"}}><span style={{fontSize:"9px",color:"#ff2d55",fontWeight:700,fontFamily:"var(--f1)",letterSpacing:"1px"}}>📡 RELATÓRIO</span><CopyBtn text={report} id="mon" cp={cp} setCp={setCp} small/></div><div style={{fontSize:"12px",lineHeight:1.65,color:"#a89d8a"}}><MD text={report}/></div></div>}
          {!report&&!monLoad&&<div style={{textAlign:"center",padding:"40px"}}><div style={{fontSize:"48px",opacity:0.2}}>📡</div><p style={{fontSize:"12px",color:"#2d2820",fontFamily:"var(--f1)",marginTop:"8px"}}>Toque Sincronizar</p></div>}
        </div>}

        {/* FACTORY */}
        {tab==="calendar"&&<div>
          <h2 style={{margin:"0 0 4px",fontSize:"17px",color:"#f0e6d3",fontFamily:"var(--f1)"}}>⚡ Fábrica de Conteúdo</h2>
          <p style={{margin:"0 0 12px",fontSize:"11px",color:"#4d4538"}}>IA gera roteiro + legenda + hashtags + estilo — tudo único</p>
          <button onClick={genWeek} disabled={genLoad!==null} style={{width:"100%",padding:"14px",borderRadius:"14px",border:"1px solid rgba(255,45,85,0.12)",background:"linear-gradient(135deg,rgba(255,45,85,0.06),rgba(191,90,242,0.03))",color:"#f0e6d3",fontSize:"13px",fontWeight:600,cursor:genLoad!==null?"wait":"pointer",fontFamily:"var(--f1)",marginBottom:"12px",opacity:genLoad!==null?0.5:1,display:"flex",alignItems:"center",justifyContent:"center",gap:"8px"}}>{genLoad!==null?<><span className="sp"/> Gerando...</>:"⚡ Gerar semana completa"}</button>
          {genError&&<Err msg={genError}/>}
          <div style={{display:"flex",flexDirection:"column",gap:"6px"}}>
            {Array.from({length:30},(_,i)=>i+1).map(dn=>{
              const d=days[dn],type=d?.type||ROT[(dn-1)%ROT.length],tc=TC[type]||TC["Versículo Dark"],isG=genLoad===dn;
              return <div key={dn} style={{...glass,padding:"12px 14px",display:"flex",gap:"10px",alignItems:"center",opacity:d?.posted?0.3:1,background:d?"rgba(255,255,255,0.03)":"rgba(255,255,255,0.01)"}}>
                {d&&<button onClick={()=>setDays(p=>({...p,[dn]:{...p[dn],posted:!p[dn]?.posted}}))} style={{width:"28px",height:"28px",borderRadius:"8px",border:d.posted?"2px solid #30d158":"2px solid rgba(255,255,255,0.08)",background:d.posted?"rgba(48,209,88,0.1)":"transparent",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",color:"#30d158",flexShrink:0,padding:0}}>{d.posted&&<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3"><polyline points="20 6 9 17 4 12"/></svg>}</button>}
                <div style={{flex:1,minWidth:0,cursor:d?"pointer":"default"}} onClick={()=>{if(d){setOpenDay(dn);setTab("day");}}}>
                  <div style={{display:"flex",alignItems:"center",gap:"6px",flexWrap:"wrap",marginBottom:"3px"}}>
                    <span style={{fontSize:"12px",fontWeight:700,color:"#f0e6d3",fontFamily:"var(--f1)"}}>{WD[(dn-1)%7]} {dn}</span>
                    <span style={{fontSize:"9px",color:"#2d2820"}}>{TM[(dn-1)%7]}</span>
                    <span style={{fontSize:"9px",padding:"3px 8px",borderRadius:"6px",background:tc.g,color:"#fff",fontWeight:700,boxShadow:`0 0 10px ${tc.gl}`}}>{tc.em} {type}</span>
                  </div>
                  {d?<p style={{margin:0,fontSize:"11.5px",color:d.posted?"#2d2820":"#a89d8a"}}>{d.titulo}</p>:<p style={{margin:0,fontSize:"10px",color:"#1d1a15",fontStyle:"italic"}}>Aguardando</p>}
                </div>
                {!d?<button onClick={()=>genDay(dn)} disabled={genLoad!==null} style={{padding:"7px 14px",borderRadius:"10px",border:"none",background:tc.g,color:"#fff",fontSize:"10px",fontWeight:700,cursor:genLoad!==null?"wait":"pointer",boxShadow:`0 0 12px ${tc.gl}`,opacity:genLoad!==null?0.3:1,whiteSpace:"nowrap"}}>{isG?<span className="sp"/>:"Gerar"}</button>
                :<div style={{display:"flex",gap:"4px",flexShrink:0}}>
                  <button onClick={e=>{e.stopPropagation();regenDay(dn);}} disabled={genLoad!==null} style={{padding:"6px 8px",borderRadius:"8px",border:"1px solid rgba(255,255,255,0.04)",background:"rgba(255,255,255,0.02)",color:"#6b6358",cursor:genLoad!==null?"wait":"pointer",display:"flex",alignItems:"center",opacity:genLoad!==null?0.2:1}}>{isG?<span className="sp"/>:<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>}</button>
                  <button onClick={()=>{setOpenDay(dn);setTab("day");}} style={{padding:"6px 12px",borderRadius:"8px",border:"none",background:"rgba(255,45,85,0.06)",color:"#ff2d55",cursor:"pointer",fontSize:"10px",fontWeight:700}}>Abrir</button>
                </div>}
              </div>;
            })}
          </div>
        </div>}

        {/* DAY DETAIL */}
        {tab==="day"&&(()=>{
          const d=days[openDay];
          if(!d)return<div style={{textAlign:"center",padding:"50px"}}><div style={{fontSize:"48px",opacity:0.2}}>📝</div><p style={{color:"#2d2820",fontFamily:"var(--f1)",fontSize:"13px",marginTop:"10px"}}>Gere conteúdo na Fábrica</p><button onClick={()=>setTab("calendar")} style={{padding:"10px 20px",borderRadius:"10px",border:"none",background:"rgba(255,45,85,0.06)",color:"#ff2d55",cursor:"pointer",fontSize:"12px",fontWeight:600,fontFamily:"var(--f1)",marginTop:"8px"}}>← Fábrica</button></div>;
          const tc=TC[d.type]||TC["Versículo Dark"];
          const secs=[{l:"🎯 GANCHO (0-3s)",c:d.gancho,cl:"#ff2d55"},{l:"📖 VERSÍCULO",c:d.versiculo,cl:"#bf5af2"},{l:"🎙️ NARRAÇÃO",c:d.narracao,cl:"#5ac8fa"},{l:"📢 CTA",c:d.cta,cl:"#30d158"},{l:"📱 LEGENDA",c:d.legenda,cl:"#ffd60a"},{l:"# HASHTAGS",c:d.hashtags,cl:"#ff6482"},{l:"🎬 EDIÇÃO",c:d.estilo_video,cl:"#bf5af2"},{l:"🖼️ CAPA",c:d.thumbnail,cl:"#ff6482"},{l:"🎵 MÚSICA",c:d.musica,cl:"#30d158"},{l:"💡 VIRALIZAR",c:d.dica_viral,cl:"#ffd60a"}];
          return <div>
            <button onClick={()=>setTab("calendar")} style={{background:"none",border:"none",color:"#ff2d55",fontSize:"11px",cursor:"pointer",fontWeight:700,fontFamily:"var(--f1)",marginBottom:"8px",padding:0}}>← FÁBRICA</button>
            <div style={{...glass,overflow:"hidden"}}>
              <div style={{padding:"18px",position:"relative",overflow:"hidden"}}><div style={{position:"absolute",inset:0,background:tc.g,opacity:0.05}}/><div style={{position:"absolute",top:0,left:0,right:0,height:"3px",background:tc.g}}/><div style={{position:"relative",display:"flex",justifyContent:"space-between",alignItems:"flex-start",flexWrap:"wrap",gap:"8px"}}><div><div style={{display:"flex",gap:"6px",marginBottom:"6px",alignItems:"center"}}><span style={{fontSize:"9px",padding:"3px 10px",borderRadius:"6px",background:tc.g,color:"#fff",fontWeight:700,boxShadow:`0 0 12px ${tc.gl}`}}>{tc.em} DIA {d.dayNum}</span><span style={{fontSize:"9px",color:"#4d4538",fontFamily:"var(--f1)"}}>{d.type}</span></div><h2 style={{margin:0,fontSize:"18px",color:"#f0e6d3",fontFamily:"var(--f1)",lineHeight:1.3}}>{d.titulo}</h2></div><div style={{display:"flex",gap:"5px"}}><button onClick={()=>regenDay(openDay)} disabled={genLoad!==null} style={{padding:"7px 12px",borderRadius:"8px",border:"1px solid rgba(255,255,255,0.06)",background:"rgba(255,255,255,0.02)",color:"#6b6358",cursor:genLoad?"wait":"pointer",fontSize:"11px",fontWeight:600}}>{genLoad===openDay?<span className="sp"/>:"↻ Novo"}</button><CopyBtn text={fullScript(d)} id={`f${d.dayNum}`} cp={cp} setCp={setCp}/></div></div></div>
              {secs.map((sec,i)=><div key={i} style={{padding:"10px 18px",borderTop:"1px solid rgba(255,255,255,0.02)"}}><div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"5px"}}><span style={{fontSize:"9px",fontWeight:700,color:sec.cl,letterSpacing:"0.8px",fontFamily:"var(--f1)"}}>{sec.l}</span><CopyBtn text={sec.c||""} id={`s${i}d${d.dayNum}`} cp={cp} setCp={setCp} small/></div><div style={{padding:"10px 12px",borderRadius:"10px",background:`${sec.cl}06`,border:`1px solid ${sec.cl}10`,fontSize:"12.5px",lineHeight:1.6,color:"#a89d8a"}}>{sec.c||"—"}</div></div>)}
              <div style={{padding:"16px 18px"}}><button onClick={()=>setDays(p=>({...p,[openDay]:{...p[openDay],posted:!p[openDay]?.posted}}))} style={{width:"100%",padding:"14px",borderRadius:"12px",border:"none",background:d.posted?"rgba(48,209,88,0.08)":"linear-gradient(135deg,rgba(255,45,85,0.08),rgba(191,90,242,0.04))",color:d.posted?"#30d158":"#f0e6d3",fontSize:"13px",fontWeight:700,cursor:"pointer",fontFamily:"var(--f1)"}}>{d.posted?"✦ Postado":"Marcar como Postado"}</button></div>
            </div>
          </div>;
        })()}

        {/* AI CHAT */}
        {tab==="ai"&&<div style={{display:"flex",flexDirection:"column",height:"calc(100vh - 150px)"}}>
          <div style={{marginBottom:"8px",flexShrink:0}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"5px"}}>
              <span style={{fontSize:"9px",color:"#2d2820",fontWeight:700,fontFamily:"var(--f1)",letterSpacing:"1.5px"}}>🔮 ORÁCULO — BUSCA WEB</span>
              <button onClick={()=>{const m=[{role:"assistant",content:"🔮 Limpo! Pergunte qualquer coisa."}];setChat(m);persistChat(m);}} style={{background:"none",border:"1px solid rgba(255,255,255,0.04)",borderRadius:"6px",padding:"3px 8px",fontSize:"9px",color:"#2d2820",cursor:"pointer"}}>Limpar</button>
            </div>
            <div style={{display:"flex",gap:"5px",overflow:"auto",paddingBottom:"4px"}}>
              {[{l:"🔥 Viral",p:"O que está viral agora TikTok devocional dark Brasil março 2026."},{l:"🎬 CapCut",p:"Tutorial edição dark no CapCut grátis passo a passo."},{l:"💰 Monetizar",p:"Formas de monetizar canal dark devocional TikTok 2026."},{l:"📊 Horários",p:"Melhores horários postar TikTok Brasil nicho religioso 2026."}].map((a,i)=>(
                <button key={i} onClick={()=>sendMsg(a.p)} disabled={chatLoad} style={{padding:"7px 12px",borderRadius:"10px",fontSize:"10px",fontWeight:600,border:"1px solid rgba(191,90,242,0.1)",background:"rgba(191,90,242,0.03)",color:"#bf5af2",cursor:chatLoad?"wait":"pointer",whiteSpace:"nowrap",opacity:chatLoad?0.3:1}}>{a.l}</button>
              ))}
            </div>
          </div>
          <div style={{flex:1,overflow:"auto",display:"flex",flexDirection:"column",gap:"8px",paddingBottom:"6px"}}>
            {chat.map((m,i)=><div key={i} style={{alignSelf:m.role==="user"?"flex-end":"flex-start",maxWidth:"94%",position:"relative"}}>
              {m.role==="assistant"&&<div style={{fontSize:"8px",color:"#2d2820",marginBottom:"3px",fontFamily:"var(--f1)",letterSpacing:"0.5px"}}>🔮 ORÁCULO</div>}
              <div style={{padding:"12px 14px",borderRadius:m.role==="user"?"14px 14px 4px 14px":"14px 14px 14px 4px",background:m.role==="user"?"linear-gradient(135deg,#ff2d55,#bf1942)":"rgba(255,255,255,0.025)",border:m.role==="user"?"none":"1px solid rgba(255,255,255,0.04)",fontSize:"12px",lineHeight:1.6,color:m.role==="user"?"#fff":"#a89d8a",boxShadow:m.role==="user"?"0 4px 15px rgba(255,45,85,0.2)":"none"}}>{m.role==="assistant"?<MD text={m.content}/>:m.content}</div>
              {m.role==="assistant"&&i>0&&<CopyBtn text={m.content} id={`ch${i}`} cp={cp} setCp={setCp} small/>}
            </div>)}
            {chatLoad&&<div style={{alignSelf:"flex-start"}}><div style={{fontSize:"8px",color:"#2d2820",marginBottom:"3px",fontFamily:"var(--f1)"}}>🔮 ORÁCULO</div><div style={{padding:"14px",borderRadius:"14px 14px 14px 4px",background:"rgba(255,255,255,0.025)",border:"1px solid rgba(255,255,255,0.04)"}}><div style={{display:"flex",gap:"5px",alignItems:"center"}}><div className="dot" style={{animationDelay:"0s"}}/><div className="dot" style={{animationDelay:"0.2s"}}/><div className="dot" style={{animationDelay:"0.4s"}}/><span style={{fontSize:"11px",color:"#4d4538",marginLeft:"6px",fontFamily:"var(--f1)"}}>Pesquisando...</span></div></div></div>}
            <div ref={chatEnd}/>
          </div>
          <div style={{flexShrink:0,display:"flex",gap:"8px",paddingTop:"8px",borderTop:"1px solid rgba(255,255,255,0.03)"}}>
            <input value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendMsg(input);}}} placeholder="Pergunte ao oráculo..." disabled={chatLoad} style={{flex:1,padding:"12px 14px",borderRadius:"12px",border:"1px solid rgba(255,255,255,0.05)",background:"rgba(255,255,255,0.02)",color:"#f0e6d3",fontSize:"13px",outline:"none",fontFamily:"var(--f2)"}}/>
            <button onClick={()=>sendMsg(input)} disabled={chatLoad||!input.trim()} style={{width:"44px",height:"44px",borderRadius:"12px",border:"none",background:input.trim()&&!chatLoad?"linear-gradient(135deg,#ff2d55,#bf1942)":"rgba(255,255,255,0.02)",cursor:input.trim()&&!chatLoad?"pointer":"default",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",boxShadow:input.trim()&&!chatLoad?"0 0 20px rgba(255,45,85,0.25)":"none"}}><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg></button>
          </div>
        </div>}
      </div>

      <style>{`
        @keyframes pulse{0%,100%{opacity:.2;transform:scale(.7)}50%{opacity:1;transform:scale(1)}}
        @keyframes spin{to{transform:rotate(360deg)}}
        .sp{display:inline-block;width:12px;height:12px;border-radius:50%;border:2px solid rgba(240,230,211,0.2);border-top-color:#f0e6d3;animation:spin .7s linear infinite}
        .sp-lg{display:inline-block;width:20px;height:20px;border-radius:50%;border:2px solid rgba(240,230,211,0.1);border-top-color:#f0e6d3;animation:spin .8s linear infinite}
        .dot{width:7px;height:7px;border-radius:50%;background:#ff2d55;animation:pulse 1.2s infinite;box-shadow:0 0 8px #ff2d5540}
        input::placeholder{color:#2d2820}
        ::-webkit-scrollbar{width:3px;height:3px}
        ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.05);border-radius:3px}
        *{box-sizing:border-box}button{font-family:var(--f2)}
      `}</style>
    </div>
  );
}

import React from 'react'
import ReactDOM from 'react-dom/client'
import App from './App'

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <App />
  </React.StrictMode>
)
